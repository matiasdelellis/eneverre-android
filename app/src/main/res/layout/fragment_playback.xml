<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    tools:context=".PlaybackFragment">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/record_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="88dp"
        android:src="@drawable/ic_video_cam_24" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/take_snapshot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp"
        android:src="@drawable/ic_camera_24" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/frameLayout"
            android:layout_width="match_parent"
            android:layout_height="250dp">

            <org.videolan.libvlc.util.VLCVideoLayout
                android:id="@+id/vlc_playback_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ProgressBar
                android:id="@+id/loading_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/timeline_frame"
            android:layout_width="match_parent"
            android:layout_height="90dp">

            <ar.com.delellis.eneverre.widget.TimelineView
                android:id="@+id/timeline_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:timelineColorPointer="#c62828"
                app:timelineColorPointerTimeText="@color/white"
                app:timelineColorPointerDateText="?attr/colorOnPrimaryContainer"
                app:timelineColorSelected1="#ffca28"
                app:timelineColorSelected2="#be8e00"
                app:timelineColorMajor1="#1DE9B6"
                app:timelineColorMajor2="#FF6D00"
                app:timelineColorBackground="?attr/colorPrimaryContainer"
                app:timelineColorNoData="?attr/colorSurfaceDim"
                app:timelineColorText="?attr/colorOnPrimaryContainer"/>
        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
