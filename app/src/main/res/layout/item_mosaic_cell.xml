<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <FrameLayout
        android:id="@+id/cell_video_frame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="2dp"
        android:background="#000000"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <org.videolan.libvlc.util.VLCVideoLayout
            android:id="@+id/cell_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Shown for cameras in privacy mode instead of a stream. -->
        <View
            android:id="@+id/cell_privacy_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/cell_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <ImageView
            android:id="@+id/cell_status_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:contentDescription="@string/camera"
            android:visibility="gone"
            tools:src="@drawable/ic_privacy_24" />

        <TextView
            android:id="@+id/cell_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#66000000"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            tools:text="@tools:sample/lorem/random" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
